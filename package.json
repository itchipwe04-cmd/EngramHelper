{
  "name": "engram-helper",
  "version": "0.1.0",
  "description": "Trợ thủ học tập chạy nền trên desktop, nhắc ôn tập theo lịch FSRS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable"
  },
  "author": "Jaki",
  "license": "ISC",
  "dependencies": {
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "tesseract.js": "^5.1.1",
    "ts-fsrs": "^4.1.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.jaki.engramhelper",
    "productName": "Engram Helper",
    "files": [
      "main.js",
      "preload.js",
      "scheduler.js",
      "config.js",
      "content-generator.js",
      "doc-extract.js",
      "ocr.js",
      "screen-translate.js",
      "tessdata/**",
      "renderer/**",
      "assets/**"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/tray-icon.png"
    }
  }
}
